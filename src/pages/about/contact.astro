---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout title="Contact" description="Contact the CSE department at IIT Gandhinagar.">
  <section class="border-b bg-muted/40">
    <div class="container py-14 md:py-18">
      <p class="text-sm font-medium text-secondary">
        Department of Computer Science &amp; Engineering, IIT Gandhinagar
      </p>
      <div class="mt-5 grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start">
        <div class="max-w-3xl">
          <h1 class="text-3xl font-semibold leading-tight md:text-5xl">
            Contact the CSE department
          </h1>
          <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
            For department-level questions, collaboration inquiries, and general
            information, write to the CSE office.
          </p>
        </div>
        <aside class="rounded-lg border border-border bg-card p-5 shadow-sm">
          <p class="font-semibold">Point of contact</p>
          <a
            href="mailto:office.cse@iitgn.ac.in"
            class="mt-3 inline-flex text-lg font-semibold text-primary underline-offset-4 hover:underline"
          >
            office.cse@iitgn.ac.in
          </a>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            This is the recommended starting point for general CSE department
            inquiries.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="grid gap-5 md:grid-cols-2">
        <article class="rounded-lg border border-border bg-card p-5 shadow-sm">
          <p class="text-sm font-medium text-secondary">Address</p>
          <h2 class="mt-3 text-xl font-semibold">IIT Gandhinagar</h2>
          <address class="mt-3 not-italic leading-relaxed text-muted-foreground">
            Department of Computer Science &amp; Engineering<br />
            Indian Institute of Technology Gandhinagar<br />
            Palaj, Gandhinagar<br />
            Gujarat 382055, India
          </address>
        </article>

        <article class="rounded-lg border border-border bg-card p-5 shadow-sm">
          <p class="text-sm font-medium text-secondary">Getting here</p>
          <h2 class="mt-3 text-xl font-semibold">Plan your campus visit</h2>
          <p class="mt-3 leading-relaxed text-muted-foreground">
            The campus is located about 26 km from Ahmedabad Airport and 28 km
            from Ahmedabad Railway Station.
          </p>
          <a
            href="/about/visit"
            class="mt-4 inline-flex text-sm font-medium text-primary underline-offset-4 hover:underline"
          >
            Plan a visit -&gt;
          </a>
        </article>
      </div>
    </div>
  </section>
</DefaultLayout>

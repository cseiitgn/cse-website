---
import JeeOpenHousePromo from '@/components/sections/jee-open-house-promo.astro';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Deadlines"
  description="Upcoming important dates, sessions, and application deadlines."
>
  <section class="from-primary/5 border-b bg-gradient-to-b to-transparent py-16 md:py-20">
    <div class="container">
      <p class="text-secondary text-sm font-medium uppercase tracking-wider">
        Updates
      </p>
      <h1 class="mt-3 text-3xl font-semibold md:text-5xl">Deadlines</h1>
      <p class="text-muted-foreground mt-4 max-w-2xl text-lg leading-relaxed">
        Upcoming important dates, information sessions, and application-related
        announcements.
      </p>
    </div>
  </section>

  <JeeOpenHousePromo variant="deadlines" />
</DefaultLayout>
